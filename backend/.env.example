# Environment: "development" or "production"
ENV=development

# JWT signing key (REQUIRED in production)
SECRET_KEY=dev-secret-change-me-in-production

# Fernet encryption key for stored API keys (REQUIRED in production)
ENCRYPTION_KEY=dev-encryption-key-change-me

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=perception

# Redis (used for Celery broker, caching, and progress tracking)
REDIS_URL=redis://localhost:6379/0

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=5
AUTH_RATE_LIMIT_WINDOW=300
AUTH_RATE_LIMIT_MAX=10
